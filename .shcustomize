# general
if [[ "$OSTYPE" == "linux-gnu"* ]]; then
  [ -f ~/.fzf.bash ] && source ~/.fzf.bash
  alias sb="source ~/.bashrc"
  alias sb="source ~/.bashrc"
  alias eb="nvim ~/dotfiles/.shcustomize && cp ~/dotfiles/.shcustomize ~/.shcustomize && bash ~/dotfiles/update_config.sh && source ~/.shcustomize && echo updated"
elif [[ "$OSTYPE" == "darwin"* ]]; then
  [ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
  alias sb="source ~/.zshrc"
  alias sb="source ~/.zshrc"
  alias eb="nvim ~/dotfiles/.shcustomize && cp ~/dotfiles/.shcustomize ~/.shcustomize && bash ~/dotfiles/update_config.sh && source ~/.shcustomize && echo updated"
fi

alias py="python"
alias lg="lazygit"
alias cde="conda deactivate"

alias sbx="cd ~/repos/sandbox/"
alias dot="cd ~/dotfiles"

# compile
alias nr="nim c -r"

# work
export FIO_LOGGING_DISABLE_JSON=1
alias remote="ssh alchen@chwld-alchen1"
alias remotebox="ssh alchen@chvld-alchen2"
alias er="conda activate fio-app-edo-risk && cd ~/repos/edo-risk"
alias erd="conda activate fio-app-edo-risk-dashboard && cd ~/repos/edo-risk-dashboard"
alias ad="conda activate fio-app-apo-dashboard && cd ~/repos/apo-dashboard/"
alias al="conda activate fio-app-alsenal && cd ~/repos/alsenal/fio/app/alsenal/scripts"
alias dgp="conda activate fio-app-desk-greek-publisher && cd ~/repos/desk-greek-publisher/"
alias em="conda activate fio-edo-metrics && cd ~/repos/edo-metrics/"
alias egp="conda activate fio-app-edo-greek-publisher && cd ~/repos/edo-greek-publisher/"
alias esmp="conda activate fio-app-exchange-status-metrics-publisher"
alias fb="conda activate fio-app-ficc-bot && cd ~/repos/ficc-bot/"
alias is="conda activate instrument-service && cd ~/repos/instrument-service"
alias ks="cd ~/repos/k8s/"
alias opds="conda activate fio-app-option-pricing-data-service && cd ~/repos/option-pricing-data-service/"
alias lgp="conda activate fio-live-greek-publisher && cd ~/repos/live-greek-publisher/"
alias ppb="conda activate fio-app-preliminary-price-bars && cd ~/repos/preliminary-price-bars"
alias ruvs="conda activate fio-app-rv-utils-viz-server && cd ~/repos/rv-utils-viz-server"
alias sgu="conda activate fio-sol-greeks-utils && cd ~/repos/sol-greeks-utils/"
alias sy="conda activate fio-symbology && cd ~/repos/symbology/"
alias tui="conda activate fio-app-alsenal && cd ~/repos/alsenal/fio/app/alsenal/tuis/"
